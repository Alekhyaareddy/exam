pipeline {
    agent any

    stages {

        stage('Clone Code') {
            steps {
                git 'https://github.com/your-repo/exam.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t exam-image .'
            }
        }

        stage('Deploy') {
            steps {
                sh 'kubectl apply -f k8s/'
            }
        }
    }
}