pipeline {
    agent any

    stages {

        stage('Clone Code') {
            steps {
                git 'https://github.com/Alekhyaareddy/exam'
            }
        }

        stage('Build Docker Image') {
            steps {
                bat 'docker build -t exam-image .'
            }
        }

        stage('Deploy') {
            steps {
                bat 'kubectl apply -f k8s/'
            }
        }
    }
}