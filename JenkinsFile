pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git 'https://github.com/Alekhyaareddy/exam'
            }
        }

        stage('Docker Build') {
            steps {
                bat 'docker build -t exam-image .'
            }
        }

        stage('Check Kubernetes') {
            steps {
                bat 'kubectl cluster-info'
                bat 'kubectl get nodes'
            }
        }

        stage('Deploy') {
            steps {
                bat 'kubectl apply -f k8s/'
            }
        }
    }
}