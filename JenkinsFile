pipeline {
    agent any

    stages {

        stage('Checkout Code') {
            steps {
                git 'https://github.com/Alekhyaareddy/exam'
            }
        }

        stage('Build Docker Image') {
            steps {
                bat 'docker build -t exam-image .'
            }
        }

        stage('Kubernetes Check') {
            steps {
                bat 'kubectl version --client'
                bat 'kubectl get nodes'
            }
        }

        stage('Deploy') {
            steps {
                bat 'kubectl --kubeconfig=C:\\Users\\Alekhya\\.kube\\.config apply -f k8s/'
            }
        }

    }
}